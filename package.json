{
	"name": "possessive-js",
	"author": "Sunan Regi Maunakea",
	"license": "MIT",
	"version": "0.1.0",
	"description": "A JavaScript library for handling singular possessive apostrophes with support for international names",
	"scripts": {
		"clean": "rm -rf dist",
		"build": "npm run clean && rollup -c rollup.config.mjs",
		"docs": "npm run docs:api",
		"docs:api": "mkdir -p docs .jsdoc-api/temp && HOME=$PWD jsdoc2md src/index.js > docs/API.md",
		"prepublishOnly": "npm run build",
		"format": "biome format --write src test docs package.json README.md rollup.config.mjs test-cjs.js test-esm.mjs index.d.ts",
		"lint": "biome lint src test rollup.config.mjs test-cjs.js test-esm.mjs index.d.ts",
		"test": "jest",
		"test:coverage": "jest --coverage",
		"pack:dry-run": "npm pack --dry-run",
		"smoke:cjs": "node test-cjs.js",
		"smoke:esm": "node test-esm.mjs",
		"smoke": "npm run smoke:cjs && npm run smoke:esm",
		"verify": "npm run lint && npm run test:coverage && npm run build && npm run smoke && npm run docs && npm run pack:dry-run",
		"release": "npm run verify && npm version"
	},
	"engines": {
		"node": ">=18"
	},
	"jest": {
		"testEnvironment": "node",
		"testMatch": [
			"**/test/**/*.test.js"
		],
		"collectCoverageFrom": [
			"src/index.js"
		],
		"coverageThreshold": {
			"global": {
				"branches": 100,
				"functions": 100,
				"lines": 100,
				"statements": 100
			}
		}
	},
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"require": "./dist/index.js",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist",
		"index.d.ts"
	],
	"keywords": [
		"possessive",
		"apostrophe",
		"grammar",
		"international",
		"names",
		"string",
		"text-processing"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@rollup/plugin-commonjs": "^28.0.1",
		"@rollup/plugin-node-resolve": "^15.3.0",
		"@rollup/plugin-terser": "^0.4.4",
		"jest": "^29.7.0",
		"jsdoc-to-markdown": "^9.1.3",
		"rollup": "^4.27.2"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sunanmau5/possessive-js.git"
	},
	"bugs": {
		"url": "https://github.com/sunanmau5/possessive-js/issues"
	},
	"homepage": "https://github.com/sunanmau5/possessive-js#readme",
	"packageManager": "npm@10.5.2+sha512.707546ed0109c09759c8eacad1d297e6e7f747915dd04f007264844b58cbb4ee76513d5e9d4299f7a3a7c3fc70ab809bad36449c3baed957fd902421fd2775db"
}
